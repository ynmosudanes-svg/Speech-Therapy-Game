generator client {
  provider      = "prisma-client-js"
  engineType    = "binary"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  THERAPIST
  PARENT
}

enum SessionType {
  CLINIC
  HOME
  FREE_PLAY
}

enum StudentRequestStatus {
  PENDING
  APPROVED
}

enum PromptLevel {
  FULL
  PARTIAL
  INDEPENDENT
  VERBAL
  VISUAL
  GESTURAL
  PHYSICAL
}

model User {
  id              String    @id @default(cuid())
  name            String
  email           String    @unique
  password        String
  role            Role
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  students        Student[] @relation("StudentTherapist")
  children        Student[] @relation("StudentParent")
  sessions        Session[]
}

model Student {
  id              String        @id @default(cuid())
  name            String
  age             Int
  diagnosis       String?
  accessCode      String        @unique
  currentLevel    Int           @default(1)
  planName        String?
  requestStatus   StudentRequestStatus @default(APPROVED)
  therapistId     String
  parentId        String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  therapist       User          @relation("StudentTherapist", fields: [therapistId], references: [id], onDelete: Restrict)
  parent          User?         @relation("StudentParent", fields: [parentId], references: [id], onDelete: SetNull)
  sessions        Session[]
  assignedGames   StudentGame[]
}

model Game {
  id              String        @id @default(cuid())
  gameCode        String?       @unique
  name            String
  title           String?
  titleAr         String?
  type            String
  level           Int
  config          Json?
  isActive        Boolean       @default(true)
  questionText    String?
  questionTextAr  String?
  questionAudio   String?
  instructionText String?
  instructionTextAr String?
  instructionAudio String?
  targetImage     String?
  options         Json?
  items           Json?
  successSound    String?
  failSound       String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  students        StudentGame[]
  sessions        Session[]
  libraries       GameLibraryItem[]
}

model GameLibrary {
  id              String            @id @default(cuid())
  name            String
  description     String?
  color           String?           @default("#19add6")
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  items           GameLibraryItem[]

  @@index([createdAt])
}

model GameLibraryItem {
  libraryId       String
  gameId          String
  order           Int               @default(0)
  addedAt         DateTime          @default(now())
  library         GameLibrary       @relation(fields: [libraryId], references: [id], onDelete: Cascade)
  game            Game              @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@id([libraryId, gameId])
}

model ImageLibrary {
  id              String    @id @default(cuid())
  url             String    @unique
  thumbnail       String
  category        String?
  source          String?
  createdAt       DateTime  @default(now())

  @@index([category])
  @@index([createdAt])
}

model MediaFolder {
  id              String       @id @default(cuid())
  name            String
  slug            String       @unique
  createdBy       String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  assets          MediaAsset[]

  @@index([name])
  @@index([createdAt])
}

model MediaAsset {
  id              String       @id @default(cuid())
  displayName     String
  originalName    String?
  filename        String
  key             String       @unique
  url             String
  thumbnail       String?
  type            String       @default("unknown")
  mimeType        String?
  size            Int          @default(0)
  category        String?
  folderId        String?
  folder          MediaFolder? @relation(fields: [folderId], references: [id], onDelete: SetNull)
  source          String       @default("upload")
  createdBy       String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([type])
  @@index([category])
  @@index([createdAt])
}

model StudentGame {
  studentId       String
  gameId          String
  order           Int           @default(0)
  assignedAt      DateTime      @default(now())
  student         Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  game            Game          @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@id([studentId, gameId])
}

model Session {
  id              String        @id @default(cuid())
  studentId       String
  therapistId     String
  gameId          String
  score           Float
  attempts        Int
  duration        Int
  sessionType     SessionType
  promptLevel     PromptLevel
  createdAt       DateTime      @default(now())
  student         Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  therapist       User          @relation(fields: [therapistId], references: [id], onDelete: Restrict)
  game            Game          @relation(fields: [gameId], references: [id], onDelete: Cascade)
}
